# ============================================
# AI Task Processing Platform — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# Do NOT commit .env to source control.

# ---- Frontend ----
# URL of the backend API (used at build time for React)
REACT_APP_API_URL=http://localhost:5000/api

# ---- Backend ----
# Port for the Express server
PORT=5000
# Environment mode (development | production)
NODE_ENV=development
# Secret key for signing JWT tokens — change this in production!
JWT_SECRET=dev-secret-key
# JWT token expiry duration
JWT_EXPIRES_IN=24h

# ---- Database ----
# MongoDB connection URI
MONGO_URI=mongodb://mongo:27017/ai_platform
# Redis connection URL
REDIS_URL=redis://redis:6379

# ---- Worker ----
# Name of the Redis queue (must match between backend and worker)
QUEUE_NAME=task_queue
# BRPOP timeout in seconds (0 = block forever, 5 = check shutdown flag every 5s)
WORKER_TIMEOUT=5
# Worker log level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
